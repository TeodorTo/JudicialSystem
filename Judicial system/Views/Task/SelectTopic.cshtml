@model IEnumerable<Judicial_system.Data.Topic>
@{
    ViewData["Title"] = "Select Topic";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h2 class="h4 mb-0">Select a Topic</h2>
                </div>
                <div class="card-body">
                    <div class="row">
                        @foreach (var topic in Model)
                        {
                            <div class="col-md-4 mb-3">
                                <a asp-action="Index" asp-controller="Task" asp-route-topicId="@topic.Id" class="btn btn-outline-primary w-100">
                                    @topic.Name
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>